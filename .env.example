# Product keys for the Windows ISOs in iso/ that REQUIRE a key at install time.
#
# Only the pre-Vista editions can't be installed without a key (their setup
# demands a CD key and has no skip). Everything Vista and newer here — the
# Enterprise client editions (Vista/7/8/8.1) and all the Server editions
# (2008/2008 R2/2012/2012 R2/2016) — installs keyless on a trial/grace period
# and is activated later (KMS/MAK), so it needs no entry here. MS-DOS 6.22 and
# Windows 3.11 have no product key at all.
#
# Copy this file to `.env` and fill in the keys. `.env` is gitignored so real
# keys never get committed; this `.env.example` is the tracked template.

# --- Windows NT ---
WINDOWS_NT4_WORKSTATION_KEY=

# --- Windows 2000 ---
WINDOWS_2000_PRO_KEY=

# --- Windows XP ---
WINDOWS_XP_PRO_X86_KEY=
WINDOWS_XP_PRO_X64_KEY=

# --- Windows Server 2003 ---
# R2 CD1 installs with the base 2003 Enterprise VLK (R2 bits on CD2 take no key).
WINDOWS_SERVER_2003_ENTERPRISE_X86_KEY=
WINDOWS_SERVER_2003_ENTERPRISE_X64_KEY=
WINDOWS_SERVER_2003_R2_ENTERPRISE_KEY=
