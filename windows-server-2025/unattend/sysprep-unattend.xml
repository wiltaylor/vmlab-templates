<?xml version="1.0" encoding="utf-8"?>
<!--
  Answer file passed to `sysprep /generalize /oobe /shutdown` at the end
  of the template build. Sysprep caches it in C:\Windows\Panther, so every
  clone of the sealed image replays it on first boot: specialize generates
  a fresh SID and a random computer name, OOBE is skipped, and the
  Administrator account comes back with the lab password plus a single
  autologon. The QEMU guest agent service survives generalize, so clones
  still report "ready".

  The guest agent can answer guest-ping WHILE specialize is still running, so
  agent-up alone is too early to call a clone "ready". A FirstLogonCommands
  entry (oobeSystem, below) writes C:\Windows\Temp\vmlab-firstboot.done after
  the autologon — i.e. once specialize + OOBE genuinely finished. vmlab's
  first-boot provision (first_boot = scripts/firstboot.wisp) waits for that
  marker, deletes it, and only then reports the VM provisioned.
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend"
          xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

  <settings pass="generalize">
    <!-- The clone runs on identical virtual hardware; keeping device
         installs makes specialize considerably faster. -->
    <component name="Microsoft-Windows-PnpSysprep"
               processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <PersistAllDeviceInstalls>true</PersistAllDeviceInstalls>
    </component>
  </settings>

  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <!-- "*" = auto-generated unique name, so multiple clones can join
           the same domain without renaming first. -->
      <ComputerName>*</ComputerName>
    </component>
  </settings>

  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <InputLocale>0409:00000409</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
      </OOBE>

      <UserAccounts>
        <AdministratorPassword>
          <Value>vmlab123!</Value>
          <PlainText>true</PlainText>
        </AdministratorPassword>
      </UserAccounts>

      <AutoLogon>
        <Enabled>true</Enabled>
        <LogonCount>1</LogonCount>
        <Username>Administrator</Username>
        <Password>
          <Value>vmlab123!</Value>
          <PlainText>true</PlainText>
        </Password>
      </AutoLogon>

      <!-- Runs on the first (auto)logon, after specialize + OOBE complete.
           Drops the marker vmlab's first-boot provision waits on. Using
           FirstLogonCommands rather than SetupComplete.cmd, which does not
           run on these generalized clones. -->
      <FirstLogonCommands>
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <CommandLine>cmd /c echo ready&gt; C:\Windows\Temp\vmlab-firstboot.done</CommandLine>
          <Description>vmlab first-boot ready marker</Description>
        </SynchronousCommand>
      </FirstLogonCommands>
    </component>
  </settings>
</unattend>
