<?xml version="1.0" encoding="utf-8"?>
<!--
  Answer file passed to `sysprep /generalize /oobe /shutdown` at the end
  of the template build. Sysprep caches it in C:\Windows\Panther, so every
  clone of the sealed image replays it on first boot: specialize generates
  a fresh SID and a random computer name, OOBE is skipped, and the
  Administrator account comes back with the lab password. The QEMU guest
  agent service survives generalize, so clones still report "ready".

  NO AutoLogon — deliberately. On modern (24H2) codebases the base build's
  "Last Known Good" shell packages (MicrosoftWindows.LKG.Search / IrisService
  / AccountsService) are reconciled during the clone's first-boot specialize.
  If Administrator is auto-logged-in during that window, the shell launches
  mid-reconciliation, the per-user AppX state is left broken, and explorer.exe
  then fail-fasts (0xc0000409 / BEX64) on every subsequent logon. Without
  autologon the first interactive logon happens after specialize settles, so
  the profile is built clean and the shell works. Clones come up at the lock
  screen (log in as vmlab / vmlab123!).

  The guest agent can answer guest-ping WHILE specialize is still running, so
  agent-up alone is too early to call a clone "ready". A specialize-pass
  RunSynchronousCommand (below) writes C:\Windows\Temp\vmlab-firstboot.done as
  SYSTEM (no logon needed); vmlab's first-boot provision
  (first_boot = scripts/firstboot.ws) waits for that marker, deletes it, and
  only then reports the VM provisioned.
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend"
          xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

  <settings pass="generalize">
    <!-- The clone runs on identical virtual hardware; keeping device
         installs makes specialize considerably faster. -->
    <component name="Microsoft-Windows-PnpSysprep"
               processorArchitecture="arm64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <PersistAllDeviceInstalls>true</PersistAllDeviceInstalls>
    </component>
  </settings>

  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="arm64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <!-- "*" = auto-generated unique name, so multiple clones can join
           the same domain without renaming first. -->
      <ComputerName>*</ComputerName>
    </component>

    <!-- Write the first-boot marker as SYSTEM during specialize (no logon
         needed, since there is no autologon). vmlab's first-boot provision
         waits for it, deletes it, then reports the clone provisioned. -->
    <component name="Microsoft-Windows-Deployment"
               processorArchitecture="arm64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>cmd /c echo ready&gt; C:\Windows\Temp\vmlab-firstboot.done</Path>
          <Description>vmlab first-boot ready marker</Description>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>
  </settings>

  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="arm64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <InputLocale>0409:00000409</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="arm64" publicKeyToken="31bf3856ad364e35"
               language="neutral" versionScope="nonSxS">
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
      </OOBE>

      <!-- Pre-create a local admin account so client OOBE skips the
           "Who's going to use this device?" screen. Combined with NO autologon
           (see header), the clone lands at the lock screen with this account
           already built — OOBE never auto-logs-in during the LKG shell-package
           reconciliation, so explorer does not fail-fast. Log in as
           vmlab / vmlab123! (the built-in Administrator keeps the same pw). -->
      <UserAccounts>
        <AdministratorPassword>
          <Value>vmlab123!</Value>
          <PlainText>true</PlainText>
        </AdministratorPassword>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>vmlab</Name>
            <Group>Administrators</Group>
            <DisplayName>vmlab</DisplayName>
            <Password>
              <Value>vmlab123!</Value>
              <PlainText>true</PlainText>
            </Password>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>
    </component>
  </settings>
</unattend>
